# ── Servidor (Vercel env vars, nunca no client) ─────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key
ANTHROPIC_API_KEY=sua-chave-anthropic
APP_SECRET=um-valor-aleatorio-longo            # protege os endpoints POST

# ── Client (embarcam no bundle JS — nada sensível aqui) ─────────────────────
VITE_APP_SECRET=um-valor-aleatorio-longo       # mesmo valor de APP_SECRET
VITE_TCG_API_KEY=sua-chave-pokemon-tcg-api     # opcional, aumenta rate limit
